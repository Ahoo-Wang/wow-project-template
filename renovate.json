{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Asia/Shanghai",
  "labels": ["dependencies"],
  "commitMessagePrefix": "fix(deps)",
  "commitMessageTopic": "{{depName}}",
  "gitAuthor": "Ahoo Wang <4384159+Ahoo-Wang@users.noreply.github.com>",
  "rangeStrategy": "bump",
  "lockFileMaintenance": { "enabled": false },
  "prHourlyLimit": 10,
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "description": "Group Spring ecosystem updates into a single PR",
      "groupName": "spring",
      "matchPackageNames": ["/^org\\.springframework/"]
    },
    {
      "description": "Group Kotlin-related updates into a single PR",
      "groupName": "kotlin",
      "matchPackageNames": ["/^org\\.jetbrains\\.kotlin/"]
    },
    {
      "description": "Group @ahoo-wang/fetcher ecosystem updates into a single PR",
      "groupName": "ahoo-wang-fetcher",
      "matchPackageNames": ["/^@ahoo-wang\\/fetcher/"]
    }
  ]
}
